# AUTHinator Environment Configuration
# Copy this file to .env and fill in the values
# DO NOT commit .env to version control

# Django Settings
DEBUG=True
SECRET_KEY=django-insecure-dev-key-change-in-production
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
DATABASE_URL=sqlite:///db.sqlite3

# CORS - Unified gateway in dev (automatically includes DEPLOY_DOMAIN if set)
CORS_ALLOWED_ORIGINS=http://localhost:8080

# External Domain Deployment (Optional)
# Leave empty for localhost-only development
# Example: DEPLOY_DOMAIN=www.inatorapp.com
DEPLOY_DOMAIN=
DEPLOY_SCHEME=https

# Frontend URL for SSO redirects (Optional)
# Defaults to unified gateway (:8080) in dev, or DEPLOY_DOMAIN in production
# Example: FRONTEND_URL=https://www.inatorapp.com
FRONTEND_URL=

# Email (console backend for development)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=noreply@AUTHinator.local

# Service Registry
SERVICE_REGISTRY_ENABLED=True
SERVICE_REGISTRATION_KEY=dev-service-key-change-in-production

# SSO Configuration (Optional - Leave empty to disable)

# Google OAuth2
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Microsoft OAuth2
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# Auth0
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_DOMAIN=

# Okta
OKTA_CLIENT_ID=
OKTA_CLIENT_SECRET=
OKTA_BASE_URL=
